{
  "name": "tboy1337-portfolio",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./tailwind.css --minify && node scripts/minify-games-css.mjs",
    "build": "npm run build:css",
    "update:projects": "node scripts/update-projects.mjs",
    "lint:js": "eslint games.js translation.js sw.js site-sw-register.js contact-form.js lib/**/*.mjs scripts/**/*.mjs tests/**/*.js",
    "lint:css": "stylelint \"**/*.css\"",
    "lint": "npm run lint:js && npm run lint:css",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.sw.json",
    "validate:html": "html-validate index.html",
    "validate:w3c": "node scripts/validate-w3c.mjs",
    "validate": "npm run validate:html && npm run validate:w3c",
    "test:unit": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:coverage": "node scripts/merge-coverage.mjs",
    "test": "npm run test:unit && npm run test:e2e && npm run test:coverage",
    "check": "npm run build:css && npm run lint && npm run typecheck && npm run validate && npm run test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@vitest/coverage-istanbul": "^4.1.9",
    "esbuild": "^0.28.0",
    "eslint": "^10.5.0",
    "html-validate": "^11.5.3",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.1.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.9",
    "w3c-css-validator": "^1.4.1"
  }
}
